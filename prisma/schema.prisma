// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Bcrypt hash - null for any user created via a future OAuth provider,
  // which is why it's optional rather than required.
  password      String?
  plan          String    @default("FREE")
  // Gamification: consecutive-day study streak and the last day it advanced.
  // lastStudyDate is nullable so existing users start with no recorded study.
  currentStreak Int       @default(0)
  lastStudyDate DateTime?
  // Monetization: FREE plans are capped at 1 generation per calendar day.
  // decksGeneratedToday is the running count for the current day; it's reset
  // in application code when lastDeckGeneratedDate rolls over to a new day
  // (nullable so existing users start with no recorded generation).
  decksGeneratedToday   Int       @default(0)
  lastDeckGeneratedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

// The next four models match the exact shape @auth/prisma-adapter expects -
// see node_modules/@auth/prisma-adapter/src/index.ts for the queries it runs
// against them. Don't rename fields without checking that file first.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

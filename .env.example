# Copy to .env and fill in real values. .env is gitignored - never commit secrets.

# Postgres connection string - e.g. from Supabase: Project Settings > Database > Connection string (URI, "Transaction" pooler mode).
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# --- NextAuth (Auth.js v5) - Credentials (email/password), no external OAuth ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# --- AI providers (server-side only - never sent from the client) ---
# FREE plans are pinned to Groq's llama-3.1-8b-instant.
GROQ_API_KEY=""
# PRO plans only. gpt-4o -> OpenAI, claude-3-5-sonnet-20240620 -> Anthropic.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Stripe (Phase 3 - subscriptions) ---
# Dashboard > Developers > API keys
STRIPE_SECRET_KEY=""
# The recurring Price id for the $10/mo Pro plan (price_...), from Products.
STRIPE_PRICE_ID=""
# Signing secret for the checkout webhook endpoint (whsec_...).
STRIPE_WEBHOOK_SECRET=""
# Optional: only needed if you use @stripe/stripe-js on the client. The hosted
# Checkout redirect flow used here does not require it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
